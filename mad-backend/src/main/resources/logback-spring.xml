<?xml version="1.0" encoding="UTF-8"?>
<!--
  MAD-ERP Simplified Console Logging Configuration
  - Console-only output for both Dev and Production environments
  - No file appenders to prevent disk capacity issues and directory collision crashes
  - Root log level set to INFO for high-fidelity production startup tracking
-->
<configuration>

    <!-- ══════════════════════════════════════════
         CONSOLE APPENDER (stdout)
         ══════════════════════════════════════════ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ══════════════════════════════════════════
         PII & VERBOSE SUPPRESSION POLICIES
         ══════════════════════════════════════════ -->

    <!-- Suppress Hibernate SQL parameter binding (prevents credentials leaking to logs) -->
    <logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Suppress Spring Security internal logs -->
    <logger name="org.springframework.security" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Suppress Hibernate SQL in production -->
    <logger name="org.hibernate.SQL" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- ══════════════════════════════════════════
         APPLICATION & AUDIT LOGGING
         ══════════════════════════════════════════ -->

    <!-- Audit loggers -->
    <logger name="net.engineeringdigest.journalApp.security.AuditAuthenticationEntryPoint" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="net.engineeringdigest.journalApp.security.AuditLoggingFilter" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="net.engineeringdigest.journalApp.config.RateLimitFilter" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Core application package logger -->
    <logger name="net.engineeringdigest.journalApp" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- ══════════════════════════════════════════
         PROFILE-BASED ROOT CONFIGURATION
         ══════════════════════════════════════════ -->
    <springProfile name="prod">
        <!-- Root set to INFO to allow visibility of database connection lifecycle -->
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
